# Embeddings: any OpenAI-compatible /v1/embeddings endpoint. Examples:
#   OpenAI:        https://api.openai.com/v1
#   OpenRouter:    https://openrouter.ai/api/v1
#   Together:      https://api.together.xyz/v1
#   Ollama:        http://localhost:11434/v1
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=

# Must produce 2048-dim vectors to match supabase/migrations/0001_init.sql
# (vector(2048)). Common dims:
#   1536 = OpenAI text-embedding-3-small
#   2048 = NVIDIA Nemotron (nvidia/llama-nemotron-embed-vl-1b-v2:free
#          via OpenRouter), BGE-large-en
#   3072 = OpenAI text-embedding-3-large
#   768  = many open-source models
# If you switch dim, also change the migration and re-run it.
EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free

# Generation: any OpenAI-compatible /v1/chat/completions endpoint. Can be a
# different provider than embeddings (e.g., OpenAI for embeddings, OpenRouter
# for generation). Same URL conventions as above.
GENERATION_BASE_URL=
GENERATION_API_KEY=
GENERATION_MODEL=gpt-4o-mini

# Supabase project. The service role key is server-only and bypasses RLS,
# so do not expose it to the browser. The migration creates the documents
# table and the match_documents RPC.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional. Cosine-similarity floor for stage-1 refusal. Default 0.72.
# Raise to refuse more often; lower to be more permissive.
# SIMILARITY_THRESHOLD=0.72
