# OpenAI-compatible API for embeddings AND generation. Both share the same
# base URL and key; only the model differs. Examples:
#   OpenAI:        https://api.openai.com/v1
#   OpenRouter:    https://openrouter.ai/api/v1
#   Together:      https://api.together.xyz/v1
#   Ollama:        http://localhost:11434/v1
OPENAI_BASE_URL=
OPENAI_API_KEY=

# Embedding model name. Must produce 1536-dim vectors to match the
# supabase/migrations/0001_init.sql schema (vector(1536)). Default
# text-embedding-3-small works for OpenAI directly. For OpenRouter, use
# a model with 1536 dims (e.g., openai/text-embedding-3-small).
EMBEDDING_MODEL=text-embedding-3-small

# Generation model name. Any OpenAI-compatible chat model works.
#   OpenAI:        gpt-4o-mini
#   OpenRouter:    openai/gpt-4o-mini
GENERATION_MODEL=gpt-4o-mini

# Supabase project. The service role key is server-only and bypasses RLS,
# so do not expose it to the browser. The migration creates the documents
# table and the match_documents RPC.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional. Cosine-similarity floor for stage-1 refusal. Default 0.72.
# Raise to refuse more often; lower to be more permissive.
# SIMILARITY_THRESHOLD=0.72
